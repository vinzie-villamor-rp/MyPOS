<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="mypos" transaction-type="RESOURCE_LOCAL">

        <class>com.rocketpartners.pos.model.Product</class>

        <properties>
            <!-- H2 in-memory database — recreated fresh on every run -->
            <property name="jakarta.persistence.jdbc.driver"   value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url"      value="jdbc:h2:mem:mypos;DB_CLOSE_DELAY=-1"/>
            <property name="jakarta.persistence.jdbc.user"     value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>

            <!-- Create schema from @Entity classes, then run import.sql to seed data -->
            <property name="hibernate.hbm2ddl.auto"            value="create"/>
            <property name="hibernate.dialect"                 value="org.hibernate.dialect.H2Dialect"/>

            <!-- Log generated SQL during development -->
            <property name="hibernate.show_sql"                value="true"/>
            <property name="hibernate.format_sql"              value="true"/>
        </properties>

    </persistence-unit>

</persistence>
